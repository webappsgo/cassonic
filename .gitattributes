# gitattributes created on 05/28/26 at 08:47

# Default: normalize line endings to LF on commit
* text=auto eol=lf

# Go source files
*.go text eol=lf

# Shell scripts
*.sh text eol=lf
entrypoint.sh text eol=lf

# Windows batch files — keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.db binary

# Diff hints
*.go diff=golang
