# =============================================================================
# Development/Debug Image - same as release but runs in debug mode
# Tagged :devel
# =============================================================================
FROM golang:alpine AS builder

RUN apk add --no-cache git bash

ARG TARGETARCH
ARG VERSION=dev
ARG BUILD_DATE
ARG COMMIT_ID

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} go build \
    -ldflags "-X 'main.Version=${VERSION}' -X 'main.CommitID=${COMMIT_ID}' -X 'main.BuildDate=${BUILD_DATE}'" \
    -o /build/binary/cassonic ./src

RUN CGO_ENABLED=0 GOOS=linux GOARCH=${TARGETARCH} go build \
    -ldflags "-X 'main.Version=${VERSION}' -X 'main.CommitID=${COMMIT_ID}' -X 'main.BuildDate=${BUILD_DATE}'" \
    -o /build/binary/cassonic-cli ./src/client

FROM alpine:latest

RUN apk add --no-cache \
    git \
    curl \
    bash \
    tini \
    tor \
    strace \
    htop

COPY --from=builder /build/binary/cassonic /usr/local/bin/cassonic
COPY --from=builder /build/binary/cassonic-cli /usr/local/bin/cassonic-cli

COPY docker/rootfs/ /

RUN chmod 755 /usr/local/bin/*

ENV MODE=development \
    DEBUG=true \
    TZ=America/New_York \
    DATABASE_DIR=/data/db/sqlite

EXPOSE 80

STOPSIGNAL SIGRTMIN+3

HEALTHCHECK --start-period=10m --interval=5m --timeout=15s --retries=3 \
    CMD /usr/local/bin/cassonic --status || exit 1

ENTRYPOINT [ "tini", "-p", "SIGTERM", "--", "/usr/local/bin/entrypoint.sh" ]
