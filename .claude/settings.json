{
  "model": "",
  "thinking": "off",
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash(go:*)",
      "Bash(make:*)",
      "Bash(docker:*)",
      "Bash(docker-compose:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(tree:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(ln:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(timeout:*)",
      "Bash(sort:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(act:*)",
      "Bash(gitcommit:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(tar:*)",
      "Bash(date:*)",
      "Bash(staticcheck:*)",
      "Bash(govulncheck:*)",
      "Bash(:*::*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:go.dev)",
      "WebFetch(domain:golang.org)"
    ],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git push:+)",
      "Bash(rm -rf /*:*)",
      "Bash(sudo:*)"
    ],
    "ask": [
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git checkout -- :*)"
    ]
  },
  "preferences": {
    "auto_commit": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write(*.go)",
        "hooks": [
          {
            "type": "command",
            "command": "gofmt -l \"$file\" 2>/dev/null | grep -q . && echo 'Error: Go file would not be formatted' >&2 && exit 1 || exit 0"
          }
        ]
      }
    ]
  },
  "env": {
    "CGO_ENABLED": "0"
  }
}
